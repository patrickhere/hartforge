    {
      "datasource": { "type": "prometheus", "uid": "effncqbguicxse" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "id": 4,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{instance=\"yams\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"yams\",mountpoint=\"/\"})",
          "legendFormat": "Root (/)",
          "refId": "A"
        }
      ],
      "title": "YAMS Root Disk",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "effncqbguicxse" },
