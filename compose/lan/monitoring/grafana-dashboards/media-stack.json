          "legendFormat": "Used {{mountpoint}}",
          "refId": "A"
        },
        {
          "expr": "node_filesystem_avail_bytes{instance=\"yams\",fstype!~\"tmpfs|overlay\"}",
          "legendFormat": "Free {{mountpoint}}",
          "refId": "B"
        }
      ],
      "title": "Disk Usage Trend (30d)",
