	# terminal clients get the plain-text resume at /
	@cli {
		header_regexp User-Agent (?i)(curl|wget|httpie|powershell)
		path /
	}
	handle @cli {
		rewrite * /resume.txt
		header Cache-Control "no-store"
		header Content-Type "text/plain; charset=utf-8"
		# GUARD: never add a cloudflare cache rule for "/" - this branch serves
		# two bodies by UA under one cache key. "/" has no extension so CF won't
		# edge-cache it by default; any future CF cache rule MUST exclude "/".
	}
	# never serve repo internals (rsync excludes these; belt and braces)
	respond /.git* 404
	respond /_src* 404
	respond /tools* 404
}

