hartforge.com {
	import protected
	root * /opt/resume
	file_server
	handle_errors {
		rewrite * /404.html
		file_server
	}
	# static site CSP - script-src self is REQUIRED for cloudflare scrape shield
	# email obfuscation (/cdn-cgi/scripts/email-decode.min.js), else the contact
	# mailto renders as [email protected]
	header Content-Security-Policy "default-src 'none'; script-src 'self' 'sha256-LSHsRXjiZyiBkdt2qyKszRjEKyYT9FzPdfePihtCxSU=' 'sha256-3h41NO8lfCZph2TIU2wbp3SuA7R6kvoc3h16nrJArW8=' https://static.cloudflareinsights.com; connect-src 'self' https://cloudflareinsights.com https://status.hartforge.dev; style-src 'unsafe-inline'; img-src 'self' data:; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
	@assets path *.png *.svg *.ico *.pdf
	header @assets Cache-Control "public, max-age=86400"
	@html path / /index.html
	header @html Cache-Control "public, max-age=600"
	# stable URL, same body for everyone - safe to cache (unlike the / rewrite)
	@txt path /resume.txt
	header @txt Cache-Control "public, max-age=600"
	# rss feed - explicit type + short cache (must not fall into the 86400 asset rule)
	header /feed.xml Content-Type "application/rss+xml; charset=utf-8"
	header /feed.xml Cache-Control "public, max-age=600"
	handle_path /api/anvil/* {
		reverse_proxy 127.0.0.1:8090
	}
	redir /rss /feed.xml
	redir /feed /feed.xml
	redir /til /writing/ permanent
	redir /til/ /writing/ permanent
	redir /til/index.html /writing/ permanent
	redir /notes /writing/ permanent
	redir /notes/ /writing/ permanent
	redir /notes/index.html /writing/ permanent
	# terminal clients get the plain-text resume at / (powershell covers the
	# windows powershell 5.1 `curl` alias for invoke-webrequest)
	@cli {
		header_regexp User-Agent (?i)(curl|wget|httpie|powershell)
		path /
	}
	handle @cli {
		rewrite * /resume.txt
		header Cache-Control "no-store"
		header Content-Type "text/plain; charset=utf-8"
		# GUARD: never add a cloudflare cache rule for "/" - this branch serves
		# two bodies by UA under one cache key. "/" has no extension so CF won't
		# edge-cache it by default; any future CF cache rule MUST exclude "/".
	}
	# never serve repo internals (rsync excludes these; belt and braces)
	respond /.git* 404
	respond /_src* 404
	respond /tools* 404
}

# bare `curl hartforge.com` arrives over plain http (curl defaults to http,
# and caddy's implicit auto-https redirect answers with an empty 308). this
# explicit http block serves CLI user agents the plain-text resume and 308s
# everyone else to https. no mtls here (tls directives don't apply to http
# listeners) - ufw only allows 80 from cloudflare ranges anyway.
http://hartforge.com {
	log
	crowdsec
	import secure_headers
	encode zstd gzip
	@cli {
		header_regexp User-Agent (?i)(curl|wget|httpie|powershell)
		path /
	}
	handle @cli {
		root * /opt/resume
		rewrite * /resume.txt
		header Cache-Control "no-store"
		header Content-Type "text/plain; charset=utf-8"
		file_server
	}
	handle {
		redir https://hartforge.com{uri} permanent
	}
}

# bare `curl canary.hartforge.com` arrives over plain http (curl defaults to
# http, and caddy's implicit auto-https redirect answers with an empty 308).
# this explicit http block serves CLI user agents the plain-text resume and
# 308s everyone else to https. no mtls here (tls directives don't apply to
# http listeners) - ufw only allows 80 from cloudflare ranges anyway.
http://canary.hartforge.com {
	log
	crowdsec
	# staging gate - creds in ~/bin/.env on the mini (CANARY_USER/CANARY_PASS)
	basic_auth {
		patrick REDACTED_BCRYPT_HASH
	}
	import secure_headers
	encode zstd gzip
	@cli {
		header_regexp User-Agent (?i)(curl|wget|httpie|powershell)
		path /
	}
	handle @cli {
		root * /opt/resume-canary
		rewrite * /resume.txt
		header Cache-Control "no-store"
		header Content-Type "text/plain; charset=utf-8"
		header X-Robots-Tag "noindex, nofollow"
		file_server
	}
	handle {
		redir https://canary.hartforge.com{uri} permanent
	}
}

