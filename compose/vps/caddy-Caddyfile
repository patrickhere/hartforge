# internal-only git listener (wg tunnel + loopback) - bypasses cloudflare so
# large pushes dodge the 100MB body cap and mtls doesnt apply. /etc/hosts on
# the mac mini points git.hartforge.dev at 172.16.98.2, vps points it at lo.
git.hartforge.dev {
	bind 172.16.98.2 127.0.0.1
	log
	import secure_headers
	encode zstd gzip
	request_body {
		max_size 512MB
	}
	reverse_proxy 127.0.0.1:3002 {
		header_up X-Real-IP {client_ip}
	}
}

