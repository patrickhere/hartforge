# UA rewrite) so a canary soak actually proves prod behavior.
canary.hartforge.com {
	import protected
	# staging gate - creds in ~/bin/.env on the mini (CANARY_USER/CANARY_PASS)
	basic_auth {
		patrick REDACTED_BCRYPT_HASH
