hartforge.dev {
	import protected
	root * /opt/landing
	file_server
	handle_errors {
		rewrite * /404.html
		file_server
	}
	# static site CSP - hashed inline script (status dots + buddy easter egg),
	# connect-src for the kuma heartbeat api
	header Content-Security-Policy "default-src 'none'; script-src 'sha256-KLm9xgZ6TPE0qMAyD9nCUGZm3VbyiPfr/Maz90uRLDE=' 'sha256-GLHqfO8zdQovXpKw3NnL8KwW3fMFmsJT7ea6a8tHxJ8=' 'sha256-8ZTGMbNDQLk69fEL1jSo0Ak3FNIWuslf8bQDwfTe6FU=' https://static.cloudflareinsights.com; connect-src https://status.hartforge.dev https://cloudflareinsights.com; style-src 'unsafe-inline'; img-src 'self' data:; base-uri 'none'; form-action 'none'; frame-ancestors 'self'"
	@assets path *.png *.svg *.ico *.pdf
	header @assets Cache-Control "public, max-age=86400"
	@html path / /index.html
	header @html Cache-Control "public, max-age=600"
	# never serve repo internals (rsync excludes these; belt and braces)
	respond /.git* 404
	respond /_src* 404
	respond /tools* 404
}

# public uptime kuma status page - NO tinyauth on purpose, but only the
# status-page routes are exposed; everything else (dashboard, socket.io) 404s
status.hartforge.dev {
	import protected
	redir / /status/hartforge 302
	@public path /status/* /assets/* /api/status-page/* /icon.svg /favicon.ico /apple-touch-icon.png /manifest.json /upload/*
	handle @public {
		@devOrigin header Origin https://hartforge.dev
		header @devOrigin Access-Control-Allow-Origin "https://hartforge.dev"
		@comOrigin header Origin https://hartforge.com
		header @comOrigin Access-Control-Allow-Origin "https://hartforge.com"
		@canaryOrigin header Origin https://canary.hartforge.com
		header @canaryOrigin Access-Control-Allow-Origin "https://canary.hartforge.com"
		@canaryDevOrigin header Origin https://canary.hartforge.dev
		header @canaryDevOrigin Access-Control-Allow-Origin "https://canary.hartforge.dev"
		reverse_proxy 127.0.0.1:3001
	}
	handle {
		respond 404
	}
}

